{
  "name": "education-marketplace-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production backend for the Education Marketplace — Node/Express + PostgreSQL/Prisma.",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "NODE_ENV=production node src/server.js",
