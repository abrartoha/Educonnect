NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
TRUST_PROXY=false

DATABASE_URL="postgresql://user@localhost:5432/education_marketplace?schema=public"

COOKIE_SECRET=change-me-64-byte-hex
JWT_ACCESS_SECRET=change-me-64-byte-hex
JWT_REFRESH_SECRET=change-me-64-byte-hex
CSRF_SECRET=change-me-64-byte-hex

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

LOG_LEVEL=debug

# Email (enquiry notifications). Optional in dev — leaving these blank falls
# back to a free Ethereal test inbox (preview URLs in the server logs).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=EduConnect <noreply@educonnect.com.au>
