NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
TRUST_PROXY=false

DATABASE_URL="postgresql://user@localhost:5432/education_marketplace?schema=public"

COOKIE_SECRET=change-me-64-byte-hex
JWT_ACCESS_SECRET=change-me-64-byte-hex
JWT_REFRESH_SECRET=change-me-64-byte-hex
CSRF_SECRET=change-me-64-byte-hex

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# Custom rate limiter overrides (optional, values in seconds)
# RL_GLOBAL_WINDOW=60
# RL_GLOBAL_LIMIT=100
# RL_API_WINDOW=60
# RL_API_LIMIT=5
# RL_API_BLOCK=900
# RL_LOGIN_WINDOW=900
# RL_LOGIN_LIMIT=5
# RL_LOGIN_BLOCK=1800
# RL_SIGNUP_WINDOW=3600
# RL_SIGNUP_LIMIT=5
# RL_SIGNUP_BLOCK=3600
# RL_DIR_LIST_WINDOW=60
# RL_DIR_LIST_LIMIT=10
# RL_DIR_LIST_BLOCK=300
# RL_DIR_READ_WINDOW=60
# RL_DIR_READ_LIMIT=20
# RL_DIR_READ_BLOCK=300
# RL_DIR_COMPARE_WINDOW=60
# RL_DIR_COMPARE_LIMIT=5
# RL_DIR_COMPARE_BLOCK=300
# RL_DIR_WRITE_WINDOW=3600
# RL_DIR_WRITE_LIMIT=5
# RL_DIR_WRITE_BLOCK=3600

LOG_LEVEL=debug

# Email (enquiry notifications). Optional in dev — leaving these blank falls
# back to a free Ethereal test inbox (preview URLs in the server logs).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=EduConnect <noreply@educonnect.com.au>


# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=user
REDIS_PASSWORD=password


# Form token secret
FORM_TOKEN_SECRET=change-me-32-byte-hex