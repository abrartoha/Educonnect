// ---------------------------------------------------------------------------
//  Core identity
// ---------------------------------------------------------------------------

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          Role
  status        AccountStatus  @default(PENDING)
  name          String
  avatarUrl     String?
  emailVerified Boolean        @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // 1:1 role profiles (only one will be set)
  university  UniversityProfile?
  agent       AgentProfile?
  consultant  ConsultantProfile?
  student     StudentProfile?

  // Activity
  refreshTokens      RefreshToken[]
  posts              Post[]
  comments           Comment[]
  postVotes          PostVote[]
  bookmarks          Bookmark[]
  reviewsWritten     Review[]        @relation("ReviewerReviews")
  reviewsReceived    Review[]        @relation("TargetReviews")
  leadsAsStudent     Lead[]          @relation("StudentLeads")
  leadsAsTarget      Lead[]          @relation("TargetLeads")
  campaigns          Campaign[]
  auditLogs          AuditLog[]

  @@index([role, status])
}